# SnapVisa Environment Variables
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to GitHub

# remove.bg API key (get from https://www.remove.bg/api)
REMOVE_BG_API_KEY=your_remove_bg_key_here

# Stripe keys (get from https://dashboard.stripe.com/apikeys)
# Use sk_test_ / pk_test_ for testing, sk_live_ / pk_live_ for production
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Your site URL
NEXT_PUBLIC_URL=https://snapvisa.co.uk
